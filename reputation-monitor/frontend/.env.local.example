# ──────────────────────────────────────────────────────────────
# ARX Reputation OS — Environment Variables
# Copy these into Vercel → Project → Settings → Environment Variables
# NEVER commit the real values to git.
# ──────────────────────────────────────────────────────────────

# ── Google OAuth ──────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create a project (or use existing)
# 3. APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 4. Application type: Web application
# 5. Authorised redirect URIs: https://YOUR_DOMAIN.vercel.app/api/auth/callback/google
#    (also add http://localhost:3000/api/auth/callback/google for local dev)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── NextAuth ──────────────────────────────────────────────────
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-random-64-char-string

# Set to your actual Vercel deployment URL (no trailing slash)
# For local dev use: http://localhost:3000
NEXTAUTH_URL=https://your-project.vercel.app

# ── YouTube Data API ──────────────────────────────────────────
# (Already in your project — keep as-is)
YOUTUBE_API_KEY=your-youtube-api-key

# ── YouTube multi-key pool (UNLIMITED, auto-discovered) ───────
# Add as many numbered keys as you like. The collection engine discovers ANY
# variable starting with YOUTUBE_API_KEY_ automatically — no code changes and
# no redeploy logic required. Empty values are ignored safely. There is NO
# hard-coded limit; YOUTUBE_API_KEY_1 … YOUTUBE_API_KEY_999 (or more) all work.
YOUTUBE_API_KEY_1=
YOUTUBE_API_KEY_2=
YOUTUBE_API_KEY_3=
# ...add YOUTUBE_API_KEY_N as needed

# Optional tuning (safe defaults applied if unset):
# Max simultaneous in-flight YouTube requests (1–50). Default: scales with keys.
# YOUTUBE_FETCH_CONCURRENCY=6
# Deep-collection result cache TTL in seconds (0 disables). Default: 90.
# YOUTUBE_CACHE_TTL_SECONDS=90
